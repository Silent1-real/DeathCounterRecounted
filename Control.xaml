<UserControl x:Class="DeathCounterRecounted.Control"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DeathCounterRecounted"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" SharedSizeGroup="Labels"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto" SharedSizeGroup="Buttons"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto" MinHeight="29.96"/>
            <RowDefinition Height="Auto" MinHeight="29.96"/>
            <RowDefinition Height="Auto" MinHeight="29.96"/>
            <RowDefinition Height="Auto" MinHeight="29.96"/>
            <RowDefinition Height="Auto" MinHeight="29.96"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="DeathCounterRecounted Plugin" FontWeight="Bold" FontSize="16" Grid.ColumnSpan="2" Margin="5,0,5,0" Height="21"/>

        <TextBlock Grid.Column="0" Grid.Row ="1" VerticalAlignment="Center" Text="Enable Plugin" Margin="5,0,5,0" Height="16"/>
        <CheckBox Name="Enable" Grid.Column="1" Grid.Row ="1" Margin="5,5,5,5" IsChecked="{Binding Enable}"/>


        <TextBlock Grid.Column="0" Grid.Row ="2" VerticalAlignment="Center" Text="Announce Player Suicide" Margin="5,0,5,0" Height="16"/>
        <CheckBox Name="AnnounceSuicide" Grid.Column="1" Grid.Row ="2" Margin="5,5,5,5" IsChecked="{Binding AnnounceSuicide}"/>

        <TextBlock Grid.Column="0" Grid.Row ="3" VerticalAlignment="Center" Text="Announce Collision Death" Margin="5,0,5,0" Height="16"/>
        <CheckBox Name="AnnounceCollisionDeath" Grid.Column="1" Grid.Row ="3" Margin="5,5,5,5" IsChecked="{Binding AnnounceCollisionDeath }"/>

        <TextBlock Grid.Column="0" Grid.Row ="4" VerticalAlignment="Center" Text="Announce Suffocation Death" Margin="5,0,5,0" Height="16"/>
        <CheckBox Name="AnnounceSuffocationDeath" Grid.Column="1" Grid.Row ="4" Margin="5,7,5,7" IsChecked="{Binding AnnounceSuffocationDeath}"/>
        <Button Grid.Column="1" Grid.Row="6" Content="Save Config" Margin="484,5,10,5" Click="SaveButton_OnClick" RenderTransformOrigin="0.46,5.447"></Button>
        <TextBlock Grid.Column="0" Grid.Row ="5"
           VerticalAlignment="Center"
           Text="Announce Death Streak"
           Margin="5,0,5,0"
           Height="16"/>

        <CheckBox Name="AnnounceDeathStreak"
          Grid.Column="1"
          Grid.Row ="5"
          Margin="5,7,5,7"
          IsChecked="{Binding AnnounceDeathStreak}"/>
    </Grid>
</UserControl>
